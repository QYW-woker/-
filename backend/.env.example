# =============================================
# 后端环境配置模板
# 复制此文件为 .env 并填入实际值
# =============================================

# 主服务端口（HTTPS，用于前端访问和拍照）
PORT=4000

# 监听地址（保持 0.0.0.0 允许局域网访问）
HOST=0.0.0.0

NODE_ENV=production

# 主服务公网/局域网地址（HTTPS，浏览器访问摄像头必须）
# 格式：https://[服务器IP]:4000
PUBLIC_URL=https://192.168.1.100:4000

# 图片下载服务端口（HTTP，手机扫码下载用）
IMAGE_HTTP_PORT=4001

# 手机扫码下载地址（必须填写，否则手机无法下载图片）
# 选项一：局域网（手机和服务器在同一WiFi下可用）
#   IMAGE_PUBLIC_URL=http://192.168.1.100:4001
# 选项二：公网穿透（推荐，手机用任意网络均可下载）
#   使用 Cloudflare Tunnel 后填入分配的地址，如：
#   IMAGE_PUBLIC_URL=https://xxxx-xxxx.trycloudflare.com
IMAGE_PUBLIC_URL=http://192.168.1.100:4001

# 临时图片过期时间（小时）
IMAGE_EXPIRE_HOURS=2

# 上传文件大小限制（MB）
MAX_FILE_SIZE_MB=10

# remove.bg API 密钥（人像抠图功能必须）
# 申请地址：https://www.remove.bg/api
REMOVE_BG_API_KEY=your_api_key_here

# 数据存储目录（可选，默认存在项目目录下）
# DATA_DIR=D:\PhotographData
