#!/usr/bin/env bash
# 停止所有服务

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$SCRIPT_DIR/.service.pid"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'

if [ ! -f "$PID_FILE" ]; then
  echo -e "${YELLOW}没有正在运行的服务（未找到 .service.pid）${RESET}"
  exit 0
fi

echo -e "${YELLOW}正在停止服务...${RESET}"

while IFS= read -r entry; do
  pid="${entry%%:*}"
  port="${entry##*:}"
  [ -z "$pid" ] && continue
  # 先尝试优雅停止
  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null
    echo -e "  已终止 PID $pid (端口 $port)"
  fi
  # 兜底：确保端口释放
  lsof -ti:"$port" 2>/dev/null | xargs kill -9 2>/dev/null || true
done < "$PID_FILE"

rm -f "$PID_FILE"
echo -e "${GREEN}服务已全部停止 ✓${RESET}"
