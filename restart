#!/usr/bin/env bash
# 启动前端(HTTPS) + 后端服务
# 用法：./restart [前端端口，默认 3000]

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FRONTEND_DIR="$SCRIPT_DIR/frontend"
BACKEND_DIR="$SCRIPT_DIR/backend"
PID_FILE="$SCRIPT_DIR/.service.pid"
LOG_DIR="$SCRIPT_DIR/.logs"
FRONTEND_PORT="${1:-3000}"
BACKEND_PORT=4000

# ── 颜色 ──────────────────────────────────────────────
GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; BOLD='\033[1m'; RESET='\033[0m'

# ── 先停止旧进程（读取 pid:port 格式）──────────────────
if [ -f "$PID_FILE" ]; then
  echo -e "${YELLOW}停止旧服务...${RESET}"
  while IFS= read -r entry; do
    pid="${entry%%:*}"
    port="${entry##*:}"
    kill "$pid" 2>/dev/null && echo -e "  已终止 PID $pid (端口 $port)" || true
    lsof -ti:"$port" 2>/dev/null | xargs kill -9 2>/dev/null || true
  done < "$PID_FILE"
  rm -f "$PID_FILE"
  sleep 0.8
fi

# 兜底：清理本次要使用的端口
lsof -ti:"$FRONTEND_PORT" | xargs kill -9 2>/dev/null || true
lsof -ti:"$BACKEND_PORT"  | xargs kill -9 2>/dev/null || true
sleep 0.3

# ── 日志目录 ──────────────────────────────────────────
mkdir -p "$LOG_DIR"

# ── 启动后端 ──────────────────────────────────────────
echo -e "${CYAN}启动后端 (端口 $BACKEND_PORT)...${RESET}"
cd "$BACKEND_DIR"
# 去掉本机系统代理（如 Clash 127.0.0.1:1082）：axios 默认读 HTTPS_PROXY，
# 会把抠图的图片上传强行走代理导致 socket hang up。remove.bg 可直连。
env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy \
  PORT=$BACKEND_PORT node server.js > "$LOG_DIR/backend.log" 2>&1 &
BACKEND_PID=$!
echo "$BACKEND_PID:$BACKEND_PORT" >> "$PID_FILE"

TRIES=0
until curl -sfk "https://localhost:$BACKEND_PORT/api/health" > /dev/null 2>&1; do
  sleep 0.4
  TRIES=$((TRIES+1))
  if [ $TRIES -ge 15 ]; then
    echo -e "${RED}后端启动超时，请查看日志：$LOG_DIR/backend.log${RESET}"
    exit 1
  fi
done
echo -e "${GREEN}  后端已就绪 ✓${RESET}"

# ── 启动前端（HTTPS）──────────────────────────────────
echo -e "${CYAN}启动前端 HTTPS (端口 $FRONTEND_PORT)...${RESET}"
cd "$FRONTEND_DIR"
/usr/local/bin/node node_modules/vite/bin/vite.js \
  --port "$FRONTEND_PORT" \
  --host \
  > "$LOG_DIR/frontend.log" 2>&1 &
FRONTEND_PID=$!
echo "$FRONTEND_PID:$FRONTEND_PORT" >> "$PID_FILE"

TRIES=0
until curl -sfk "https://localhost:$FRONTEND_PORT/" > /dev/null 2>&1; do
  sleep 0.5
  TRIES=$((TRIES+1))
  if [ $TRIES -ge 20 ]; then
    echo -e "${RED}前端启动超时，请查看日志：$LOG_DIR/frontend.log${RESET}"
    exit 1
  fi
done
echo -e "${GREEN}  前端已就绪 ✓${RESET}"

# ── 获取局域网 IP ──────────────────────────────────────
LOCAL_IP=$(ifconfig | grep 'inet ' | grep -v '127.0.0.1' | awk '{print $2}' | head -1)

# ── 打印访问信息 ───────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}服务已启动${RESET}"
echo -e "  前端：   ${CYAN}https://localhost:$FRONTEND_PORT${RESET}"
[ -n "$LOCAL_IP" ] && \
echo -e "  局域网：${CYAN}https://$LOCAL_IP:$FRONTEND_PORT${RESET}  ← 手机扫码访问（摄像头可用）"
echo -e "  后端：   ${CYAN}http://localhost:$BACKEND_PORT${RESET}"
echo ""
echo -e "  日志：  ${YELLOW}.logs/frontend.log${RESET} / ${YELLOW}.logs/backend.log${RESET}"
echo -e "  停止：  ${YELLOW}./stop${RESET}"
echo ""
